generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  phoneNumber  String   @default("")
  address      String   @default("")
  // Self-chosen public alias shown to other users instead of a bare code —
  // never the real name. A short system suffix is appended for uniqueness.
  nickname     String?
  createdAt    DateTime @default(now())

  emailVerified        Boolean   @default(false)
  emailVerifyCode      String?
  emailVerifyExpiresAt DateTime?

  // Set when a password reset is requested; cleared once used or replaced
  // by a newer request.
  passwordResetCode      String?
  passwordResetExpiresAt DateTime?

  // Set by an admin after manually confirming the person's phone/ID —
  // there's no automated ID/phone verification provider wired up.
  identityVerifiedAt DateTime?

  // Loyalty points earned from completed orders (both as buyer and seller),
  // redeemable 1 point = 1 satang off a future platform fee. Balance is
  // denormalized here for fast reads; PointsTransaction is the audit log.
  pointsBalance Int @default(0)

  // Set by an admin after repeated "unfair price" reports on this seller's
  // listings — blocks new listings until cleared.
  listingRestrictedAt DateTime?

  listings    Listing[]
  orders      Order[]     @relation("BuyerOrders")
  buyRequests BuyRequest[]

  reviewsGiven    Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")

  conversationsAsBuyer Conversation[] @relation("ConversationsAsBuyer")
  messagesSent         Message[]      @relation("MessagesSent")

  orderReports      OrderReport[]
  favorites         Favorite[]
  listingReports    ListingReport[]
  pointsTransactions PointsTransaction[]
  adminActions      AdminActionLog[]
}

enum PointsTransactionReason {
  EARNED_PURCHASE
  EARNED_SALE
  REDEEMED_FEE_DISCOUNT
  ADMIN_ADJUSTMENT
}

// Audit log backing User.pointsBalance — positive amount = earned,
// negative = spent/removed.
model PointsTransaction {
  id     String                   @id @default(cuid())
  amount Int
  reason PointsTransactionReason

  user   User   @relation(fields: [userId], references: [id])
  userId String

  orderId String?

  createdAt DateTime @default(now())
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  eventName   String
  venue       String
  eventDate   DateTime
  section     String?
  quantity    Int           @default(1)
  priceCents  Int
  // Original ticket price the seller paid, used to cap resale markup.
  // Nullable because listings created before this field existed have no
  // value on file — they're grandfathered in without a cap.
  faceValueCents Int?
  description String?
  imageUrl    String?
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller   User   @relation(fields: [sellerId], references: [id])
  sellerId String

  order Order?

  // If this listing was created in response to a buy request, linking it
  // here lets the request auto-close once this listing sells.
  fulfillsRequest   BuyRequest? @relation(fields: [fulfillsRequestId], references: [id])
  fulfillsRequestId String?

  conversations Conversation[]
  favoritedBy   Favorite[]
  reports       ListingReport[]
}

enum ListingReportStatus {
  OPEN
  RESOLVED
}

// Pre-purchase "this price looks unfair" flag — distinct from OrderReport,
// which is a post-purchase dispute tied to a completed order.
model ListingReport {
  id      String              @id @default(cuid())
  message String
  status  ListingReportStatus @default(OPEN)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  reporter   User   @relation(fields: [reporterId], references: [id])
  reporterId String

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@unique([listingId, reporterId, status])
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  @@unique([userId, listingId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  buyer   User   @relation("ConversationsAsBuyer", fields: [buyerId], references: [id])
  buyerId String

  messages Message[]

  @@unique([listingId, buyerId])
}

model Message {
  id   String @id @default(cuid())
  body String

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   User   @relation("MessagesSent", fields: [senderId], references: [id])
  senderId String

  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id                 String      @id @default(cuid())
  status             OrderStatus @default(COMPLETED)
  totalCents         Int
  platformFeeCents   Int         @default(0)
  sellerPayoutCents  Int         @default(0)
  // Photo of the physical/digital ticket (or its QR/barcode) the seller
  // uploads after the sale, so the buyer has proof beyond the chat thread.
  ticketProofUrl     String?
  // % knocked off the seller's platform fee for being a verified, proven
  // seller at the time of this sale — recorded here (rather than derived
  // later) so the receipt stays accurate even if the seller's status changes.
  feeDiscountPercent Int         @default(0)
  // Loyalty points earned by each party on this order, and points the
  // seller spent (1 point = 1 satang) reducing their fee on this sale.
  pointsEarnedByBuyer   Int      @default(0)
  pointsEarnedBySeller  Int      @default(0)
  pointsRedeemedBySeller Int     @default(0)
  createdAt          DateTime    @default(now())

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @unique

  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId String

  reviews Review[]
  reports OrderReport[]
}

model Review {
  id      String @id @default(cuid())
  rating  Int
  comment String?

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewerId String

  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  revieweeId String

  createdAt DateTime @default(now())

  @@unique([orderId, reviewerId])
}

enum OrderReportReason {
  TICKET_NOT_RECEIVED
  WRONG_OR_INVALID_TICKET
  PAYMENT_ISSUE
  OTHER
}

enum OrderReportStatus {
  OPEN
  RESOLVED
}

model OrderReport {
  id      String            @id @default(cuid())
  reason  OrderReportReason
  message String
  status  OrderReportStatus @default(OPEN)

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  reporter   User   @relation(fields: [reporterId], references: [id])
  reporterId String

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@unique([orderId, reporterId, status])
}

enum BuyRequestStatus {
  OPEN
  FULFILLED
  CANCELLED
}

model BuyRequest {
  id            String           @id @default(cuid())
  eventName     String
  venue         String?
  eventDate     DateTime
  quantity      Int              @default(1)
  maxPriceCents Int
  notes         String?
  imageUrl      String?
  status        BuyRequestStatus @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  buyer   User   @relation(fields: [buyerId], references: [id])
  buyerId String

  fulfillingListings Listing[]
}

model AdminNotification {
  id      String @id @default(cuid())
  message String

  eventName String
  eventDate DateTime

  buyerName  String
  buyerPhone String
  buyerEmail String

  sellerName  String
  sellerPhone String
  sellerEmail String

  buyRequestId String
  listingId    String

  readAt    DateTime?
  createdAt DateTime  @default(now())
}

enum AdminActionType {
  USER_VERIFIED
  USER_UNVERIFIED
  SELLER_RESTRICTED
  SELLER_UNRESTRICTED
  ORDER_REPORT_RESOLVED
  LISTING_REPORT_RESOLVED
  MATCH_MARKED_CALLED
  SETTINGS_UPDATED
  ANNOUNCEMENT_CREATED
  ANNOUNCEMENT_UPDATED
  ANNOUNCEMENT_DELETED
}

// Audit trail of admin actions — with multiple admins sharing the same
// panel, this is how one admin sees what another already handled instead
// of duplicating or losing track of work.
model AdminActionLog {
  id     String          @id @default(cuid())
  action AdminActionType
  // Human-readable context (target user's name, event name, etc.) — plain
  // text rather than a generic polymorphic relation since each action type
  // points at a different model.
  targetLabel String?

  admin   User   @relation(fields: [adminId], references: [id])
  adminId String

  createdAt DateTime @default(now())
}

enum AnnouncementPriority {
  CRITICAL
  GENERAL
}

enum AnnouncementAudience {
  USERS
  ADMINS
}

// Admin-authored news/banners. Not capped at the database level — the admin
// management page can hold any number for history/editing — display always
// queries for the single latest active CRITICAL and the 5 latest active
// GENERAL announcements per audience, so the "max 1 / max 5" rule lives in
// the read query rather than blocking creation.
model Announcement {
  id        String               @id @default(cuid())
  title     String
  body      String
  linkUrl   String?
  linkLabel String?
  priority  AnnouncementPriority
  audience  AnnouncementAudience
  isActive  Boolean              @default(true)
  publishAt DateTime             @default(now())
  expiresAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([audience, priority, isActive, publishAt])
}

model PlatformSettings {
  id String @id @default("singleton")

  // Fee tiers: rate1 applies up to tier1MaxBaht, rate2 up to tier2MaxBaht, rate3 above that.
  tier1MaxBaht Int   @default(1000)
  tier1Rate    Float @default(0.05)
  tier2MaxBaht Int   @default(5000)
  tier2Rate    Float @default(0.04)
  tier3Rate    Float @default(0.03)

  // Anti-scalping cap: resale price can't exceed this % of the seller's
  // declared face value. 150 = up to 1.5x face value (50% markup).
  maxResaleMarkupPercent Int @default(150)

  // Sellers who are identity-verified and have at least this many completed
  // sales get their platform fee cut by this percentage, as a loyalty perk.
  trustedSellerMinSales           Int @default(5)
  trustedSellerFeeDiscountPercent Int @default(20)

  // % of an order's total that both buyer and seller earn as points
  // (1 point = 1 satang), redeemable against a seller's future platform fee.
  pointsEarnRatePercent Int @default(1)

  // A seller whose listings have collected this many "unfair price" reports
  // (across any status) gets surfaced to admins as a repeat offender.
  sellerReportWarningThreshold Int @default(3)

  // Comma-separated list of account emails permitted to view /admin.
  adminEmails String @default("")

  // Public contact identities shown to platform users.
  lineId       String?
  instagramId  String?
  phoneNumber  String?

  updatedAt DateTime @updatedAt
}
