generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  phoneNumber  String   @default("")
  address      String   @default("")
  createdAt    DateTime @default(now())

  emailVerified        Boolean   @default(false)
  emailVerifyCode      String?
  emailVerifyExpiresAt DateTime?

  phoneVerified        Boolean   @default(false)
  phoneVerifyCode      String?
  phoneVerifyExpiresAt DateTime?

  listings    Listing[]
  orders      Order[]     @relation("BuyerOrders")
  buyRequests BuyRequest[]

  reviewsGiven    Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")

  conversationsAsBuyer Conversation[] @relation("ConversationsAsBuyer")
  messagesSent         Message[]      @relation("MessagesSent")
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  eventName   String
  venue       String
  eventDate   DateTime
  section     String?
  quantity    Int           @default(1)
  priceCents  Int
  description String?
  imageUrl    String?
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller   User   @relation(fields: [sellerId], references: [id])
  sellerId String

  order Order?

  // If this listing was created in response to a buy request, linking it
  // here lets the request auto-close once this listing sells.
  fulfillsRequest   BuyRequest? @relation(fields: [fulfillsRequestId], references: [id])
  fulfillsRequestId String?

  conversations Conversation[]
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  buyer   User   @relation("ConversationsAsBuyer", fields: [buyerId], references: [id])
  buyerId String

  messages Message[]

  @@unique([listingId, buyerId])
}

model Message {
  id   String @id @default(cuid())
  body String

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   User   @relation("MessagesSent", fields: [senderId], references: [id])
  senderId String

  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id                 String      @id @default(cuid())
  status             OrderStatus @default(COMPLETED)
  totalCents         Int
  platformFeeCents   Int         @default(0)
  sellerPayoutCents  Int         @default(0)
  createdAt          DateTime    @default(now())

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @unique

  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId String

  reviews Review[]
}

model Review {
  id      String @id @default(cuid())
  rating  Int
  comment String?

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewerId String

  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  revieweeId String

  createdAt DateTime @default(now())

  @@unique([orderId, reviewerId])
}

enum BuyRequestStatus {
  OPEN
  FULFILLED
  CANCELLED
}

model BuyRequest {
  id            String           @id @default(cuid())
  eventName     String
  venue         String?
  eventDate     DateTime
  quantity      Int              @default(1)
  maxPriceCents Int
  notes         String?
  imageUrl      String?
  status        BuyRequestStatus @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  buyer   User   @relation(fields: [buyerId], references: [id])
  buyerId String

  fulfillingListings Listing[]
}

model AdminNotification {
  id      String @id @default(cuid())
  message String

  eventName String
  eventDate DateTime

  buyerName  String
  buyerPhone String
  buyerEmail String

  sellerName  String
  sellerPhone String
  sellerEmail String

  buyRequestId String
  listingId    String

  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model PlatformSettings {
  id String @id @default("singleton")

  // Fee tiers: rate1 applies up to tier1MaxBaht, rate2 up to tier2MaxBaht, rate3 above that.
  tier1MaxBaht Int   @default(1000)
  tier1Rate    Float @default(0.05)
  tier2MaxBaht Int   @default(5000)
  tier2Rate    Float @default(0.04)
  tier3Rate    Float @default(0.03)

  // Comma-separated list of account emails permitted to view /admin.
  adminEmails String @default("")

  // Public contact identities shown to platform users.
  lineId       String?
  instagramId  String?
  phoneNumber  String?

  updatedAt DateTime @updatedAt
}
